import { useEffect, useState } from "react";
import { Leaf, Ban, Dog, ChevronRight, ChevronLeft, Shield, Truck, Box, Star, Check, Clock, Tag } from "lucide-react";
import dogBanner1 from "../../assets/banners/dog-banner.jpeg";
import heroBanner from "../../assets/banners/hero-banner.png";
import offerBanner from "../../assets/banners/offer-banner.jpeg";
import trustBanner from "../../assets/banners/trust-banner.jpeg";

const banners = [
  {
    src: dogBanner1,
    alt: "Dog and pet products banner",
    content: {
      title: ["From Fresh Meals", "to Happy Treats."],
      subtitle: "A Complete Dog Nutrition Range.",
      features: [
        { key: "leaf", label: "Real Ingredients" },
        { key: "ban", label: "No Preservatives" },
        { key: "dog", label: "For All Breeds" },
      ],
      button: { label: "Shop Now", href: "/shop", variant: "primary" },
    },
  },
  {
    src: heroBanner,
    alt: "Pet care hero banner",
    content: {
      title: ["Your Pet's Health", "Fully Covered"],
      subtitle: "Vet-Recommended Medicines & Supplies",
      features: [
        { key: "shield", label: "Assured Quality" },
        { key: "truck", label: "Express Delivery" },
        { key: "box", label: "Genuine Products" },
      ],
      button: { label: "Browse Medicines", href: "/medicines", variant: "secondary" },
    },
  },
  {
    src: offerBanner,
    alt: "Special offer banner",
    content: {
      title: ["Limited Time", "Offers"],
      subtitle: "Up to 50% off selected brands",
      features: [
        { key: "sale", label: "Best Prices" },
        { key: "clock", label: "Limited Stock" },
      ],
      button: { label: "View Offers", href: "/offers", variant: "primary" },
    },
  },
  {
    src: trustBanner,
    alt: "Trusted pet products banner",
    content: {
      title: ["Trusted Brands", "For Your Pets"],
      subtitle: "Quality products you can rely on",
      features: [
        { key: "star", label: "Top Rated" },
        { key: "check", label: "Verified Sellers" },
      ],
      button: { label: "Shop Trusted", href: "/brands", variant: "secondary" },
    },
  },
];

function renderFeatureIcon(key) {
  const props = { size: 18, className: "text-[#8B4513]" };
  switch (key) {
    case "leaf":
      return <Leaf {...props} />;
    case "ban":
      return <Ban {...props} />;
    case "dog":
      return <Dog {...props} />;
    case "shield":
      return <Shield {...props} />;
    case "truck":
      return <Truck {...props} />;
    case "box":
      return <Box {...props} />;
    case "star":
      return <Star {...props} />;
    case "check":
      return <Check {...props} />;
    case "clock":
      return <Clock {...props} />;
    case "sale":
      return <Tag {...props} />;
    default:
      return <Tag {...props} />;
  }
}

const HeroBanner = () => {
  const [index, setIndex] = useState(0);

  useEffect(() => {
    const id = setInterval(() => {
      setIndex((i) => (i + 1) % banners.length);
    }, 5000);
    return () => clearInterval(id);
  }, []);

  const prev = () => setIndex((i) => (i - 1 + banners.length) % banners.length);
  const next = () => setIndex((i) => (i + 1) % banners.length);

  return (
    <section aria-label="Homepage hero" className="w-full">
      <div className="max-w-[1440px] mx-auto relative min-h-[420px] lg:min-h-[520px] overflow-hidden" style={{height: 'clamp(420px, 45vh, 520px)'}}>

        {/* Carousel images: absolute stacked, fade transition */}
        <div className="relative w-full h-full">
          {banners.map((b, i) => (
            <img
              key={i}
              src={b.src}
              alt={b.alt}
              loading={i === 0 ? "eager" : "lazy"}
              className={`w-full h-full object-cover object-right bg-white transition-opacity duration-700 ${i === index ? "opacity-100 block lg:absolute lg:inset-0" : "opacity-0 pointer-events-none hidden lg:block"}`}
              style={{ aspectRatio: '16/7' }}
            />
          ))}

          {/* Prev/Next controls */}
          <button aria-label="Previous banner" onClick={prev} className="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-white/70 rounded-full p-2 hover:bg-white">
            <ChevronLeft size={20} />
          </button>
          <button aria-label="Next banner" onClick={next} className="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-white/70 rounded-full p-2 hover:bg-white">
            <ChevronRight size={20} />
          </button>

          {/* Indicators */}
          <div className="absolute left-1/2 -translate-x-1/2 bottom-6 z-20 flex items-center gap-2">
            {banners.map((_, i) => (
              <button
                key={i}
                aria-label={`Go to slide ${i + 1}`}
                onClick={() => setIndex(i)}
                className={`w-3 h-3 rounded-full ${i === index ? 'bg-white' : 'bg-white/60'}`}
              />
            ))}
          </div>
        </div>

        {/* Content overlay: positioned inside banner to avoid overflow */}
        <div className="lg:absolute inset-0 z-10 pointer-events-none">
          <div className="h-full flex items-center">
            <div className="px-4 md:px-8 lg:px-0 w-full md:max-w-[720px] lg:max-w-none">

              {/* Left content wrapper - absolute but constrained to banner area */}
              {/* Dynamic content for active slide */}
              {banners[index] && (
                <div className="lg:absolute left-4 md:left-8 lg:left-10 top-1/2 lg:-translate-y-1/2 w-[88%] max-w-[360px] z-20 bg-white/30 p-3 md:p-4 lg:p-5 rounded-xl pointer-events-auto">
                  <h1 className="text-[#8B4513] font-extrabold leading-[1.02] tracking-[-0.02em] mb-3 text-[28px] md:text-[36px] lg:text-[44px]" style={{fontWeight:800}}>
                    {banners[index].content.title.map((t, i) => (
                      <span key={i} className="block">{t}</span>
                    ))}
                  </h1>

                  <p className="text-[13px] md:text-[14px] lg:text-[16px] text-[#222] mt-2 mb-4">{banners[index].content.subtitle}</p>

                  <div className="flex items-center gap-4 mb-4 flex-nowrap">
                    {banners[index].content.features.map((f, i) => (
                      <div key={i} className="flex flex-col items-center text-center">
                        <div className="w-[48px] h-[48px] rounded-full border border-[#8B4513] flex items-center justify-center mb-1">
                          {renderFeatureIcon(f.key)}
                        </div>
                        <div className="text-[12px] font-medium text-[#3F3F46]" dangerouslySetInnerHTML={{ __html: f.label.replace(/\n/g, '<br/>') }} />
                      </div>
                    ))}
                  </div>

                  <a
                    href={banners[index].content.button.href}
                    className="inline-flex items-center justify-center gap-3 bg-[#F59E0B] text-white rounded-full transition-transform duration-150 hover:scale-105 px-4 py-2.5 min-w-[120px] md:min-w-[140px] text-sm font-semibold whitespace-nowrap"
                  >
                    <span>{banners[index].content.button.label}</span>
                    <ChevronRight size={18} className="text-white" />
                  </a>
                </div>
              )}

            </div>
          </div>
        </div>

      </div>
    </section>
  );
};

export default HeroBanner;